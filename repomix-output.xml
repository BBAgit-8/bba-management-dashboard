  logType?: TimeLogType
  notes?: string
}

export interface ClientSubscription {
  id: string
  clientId: string
  softwareName: string
  tier?: string
  ourCost: number
  clientPrice: number
  billingCadence: BillingCadence
}

export interface CallLog {
