import { NextRequest, NextResponse } from 'next/server'
import { prisma } from '@/lib/prisma'

// GET /api/clients/[code] — full client record with all relations
export async function GET(
  _req: NextRequest,
  { params }: { params: Promise<{ code: string }> }
): Promise<NextResponse> {
  const { code } = await params
  try {
    const row = await prisma.client.findUnique({
      where: { harvestProjectCode: code },
      include: {
        tags:          { include: { tag: true } },
        sows:          true,
        timeLogs:      { include: { employee: true }, orderBy: { logDate: 'desc' } },
        callLogs:      { orderBy: { callDate: 'desc' } },
        subscriptions: true,
      },
    })
    if (!row) {
      return NextResponse.json({ error: `Client "${code}" not found` }, { status: 404 })
    }
    const client = {
      ...row,
      tags: row.tags.map(ct => ct.tag),
      autoPriceIncreasePercent: row.autoPriceIncreasePercent != null ? Number(row.autoPriceIncreasePercent) : null,
      softwareRate:             row.softwareRate             != null ? Number(row.softwareRate)             : null,
      totalMonthlyAmount:       row.totalMonthlyAmount       != null ? Number(row.totalMonthlyAmount)       : null,
      contractStartDate:   row.contractStartDate?.toISOString()   ?? null,
      priceAdjustmentDate: row.priceAdjustmentDate?.toISOString() ?? null,
      contractEndDate:     row.contractEndDate?.toISOString()     ?? null,
      createdAt: row.createdAt.toISOString(),
      updatedAt: row.updatedAt.toISOString(),
      sows: row.sows.map(s => ({
        ...s,
        fixedMonthlyRate: s.fixedMonthlyRate != null ? Number(s.fixedMonthlyRate) : null,
        targetHours:      s.targetHours      != null ? Number(s.targetHours)      : null,
        expectedHours:    s.expectedHours    != null ? Number(s.expectedHours)    : null,
        billingRate:      s.billingRate      != null ? Number(s.billingRate)      : null,
        createdAt: s.createdAt.toISOString(),
        updatedAt: s.updatedAt.toISOString(),
      })),
      timeLogs: row.timeLogs.map(l => ({
        ...l,
        hoursLogged: Number(l.hoursLogged),
        logDate:  l.logDate  instanceof Date ? l.logDate.toISOString()  : l.logDate,
        createdAt: l.createdAt.toISOString(),
        updatedAt: l.updatedAt.toISOString(),
        employee: l.employee ? {
          id: l.employee.id,
          name: l.employee.name,
          effectiveHourlyRate: Number(l.employee.effectiveHourlyRate),
        } : null,
      })),
      callLogs: row.callLogs.map(l => ({
        ...l,
        callDate:  l.callDate  instanceof Date ? l.callDate.toISOString()  : l.callDate,
        createdAt: l.createdAt.toISOString(),
        updatedAt: l.updatedAt.toISOString(),
      })),
      subscriptions: row.subscriptions.map(s => ({
        ...s,
        ourCost:     Number(s.ourCost),
        clientPrice: Number(s.clientPrice),
        createdAt: s.createdAt.toISOString(),
        updatedAt: s.updatedAt.toISOString(),
      })),
    }
    return NextResponse.json({ client }, {
      headers: { 'Cache-Control': 'no-store, max-age=0, must-revalidate' },
    })
  } catch (err) {
    console.error('[GET /api/clients/[code]]', err)
    return NextResponse.json({ error: err instanceof Error ? err.message : String(err) }, { status: 500 })
  }
}

const ALLOWED: Set<string> = new Set([
  'archiveStatus',
  'projectType', 'revenueType', 'entityType',
  'contractStartDate', 'contractEndDate',
  'guaranteedDeadlineDay',
  'softwareRate', 'totalMonthlyAmount',
  'hasContractedLoom', 'hasScheduledMeetings', 'hasSignedAutoIncrease',
])

// PATCH /api/clients/[code]
// Accepts a partial update object for a client identified by its harvestProjectCode.
// Only fields listed in ALLOWED are accepted; all others are silently dropped.

export async function PATCH(
  req: NextRequest,
  { params }: { params: Promise<{ code: string }> }
): Promise<NextResponse> {
  const { code } = await params

  let body: unknown
  try { body = await req.json() } catch {
    return NextResponse.json({ error: 'Request body must be valid JSON' }, { status: 400 })
  }

  const raw = (body ?? {}) as Record<string, unknown>
  const data: Record<string, unknown> = {}
  for (const [k, v] of Object.entries(raw)) {
    if (ALLOWED.has(k)) data[k] = v
  }

  if (Object.keys(data).length === 0) {
    return NextResponse.json({ error: 'No valid fields provided' }, { status: 422 })
  }

  // Coerce date strings to proper DateTime for Prisma
  for (const key of ['contractStartDate', 'contractEndDate', 'priceAdjustmentDate']) {
    if (key in data) {
      data[key] = data[key] ? new Date(data[key] as string) : null
    }
  }

  try {
    const client = await prisma.client.update({
      where: { harvestProjectCode: code },
      data,
    })
    return NextResponse.json({ client })
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err)
    if (msg.includes('Record to update not found') || msg.includes('does not exist')) {
      return NextResponse.json({ error: `Client "${code}" not found` }, { status: 404 })
    }
    return NextResponse.json({ error: `Database error: ${msg}` }, { status: 500 })
  }
}
