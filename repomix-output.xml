import { NextRequest, NextResponse } from 'next/server'
import { revalidatePath } from 'next/cache'
import { prisma } from '@/lib/prisma'

// GET /api/clients — return all clients with tags + sows for live table rendering
export async function GET(): Promise<NextResponse> {
  try {
    const rows = await prisma.client.findMany({
      include: {
        tags: { include: { tag: true } },
        sows: true,
      },
      orderBy: { name: 'asc' },
    })

    // Normalise Prisma Decimal / Date types to plain JSON-safe values
    const clients = rows.map(c => ({
      ...c,
      tags: c.tags.map(ct => ct.tag),
      autoPriceIncreasePercent: c.autoPriceIncreasePercent != null ? Number(c.autoPriceIncreasePercent) : null,
      softwareRate:             c.softwareRate             != null ? Number(c.softwareRate)             : null,
      totalMonthlyAmount:       c.totalMonthlyAmount       != null ? Number(c.totalMonthlyAmount)       : null,
      contractStartDate:  c.contractStartDate?.toISOString()  ?? null,
      priceAdjustmentDate:c.priceAdjustmentDate?.toISOString() ?? null,
      contractEndDate:    c.contractEndDate?.toISOString()    ?? null,
      createdAt: c.createdAt.toISOString(),
      updatedAt: c.updatedAt.toISOString(),
      sows: c.sows.map(s => ({
        ...s,
        fixedMonthlyRate: s.fixedMonthlyRate != null ? Number(s.fixedMonthlyRate) : null,
        targetHours:      s.targetHours      != null ? Number(s.targetHours)      : null,
        expectedHours:    s.expectedHours    != null ? Number(s.expectedHours)    : null,
        billingRate:      s.billingRate      != null ? Number(s.billingRate)      : null,
        createdAt: s.createdAt.toISOString(),
        updatedAt: s.updatedAt.toISOString(),
      })),
    }))

    return NextResponse.json({ clients }, {
      headers: { 'Cache-Control': 'no-store, max-age=0, must-revalidate' },
    })
  } catch (err) {
    console.error('[GET /api/clients]', err)
    return NextResponse.json({ error: err instanceof Error ? err.message : String(err) }, { status: 500 })
  }
}

// POST /api/clients — create a new client record

export async function POST(req: NextRequest): Promise<NextResponse> {
  let body: unknown
  try {
    body = await req.json()
  } catch {
    return NextResponse.json({ error: 'Request body must be valid JSON' }, { status: 400 })
  }

  const raw = (body ?? {}) as Record<string, unknown>

  // Diagnostic log — visible in Vercel Functions real-time log
  console.log('[POST /api/clients] received payload:', {
    name:                     raw.name,
    harvestProjectCode:       raw.harvestProjectCode,
    processingCadence:        raw.processingCadence,
    projectType:              raw.projectType,
    revenueType:              raw.revenueType,
    entityType:               raw.entityType,
    einNumber:                raw.einNumber,
    contractStartDate:        raw.contractStartDate,
    officeType:               raw.officeType,
    hasPayroll:               raw.hasPayroll,
    payrollProvider:          raw.payrollProvider,
    referredBy:               raw.referredBy,
    accountantName:           raw.accountantName,
    guaranteedDeadlineDay:    raw.guaranteedDeadlineDay,
    autoPriceIncreasePercent: raw.autoPriceIncreasePercent,
    priceAdjustmentDate:      raw.priceAdjustmentDate,
    okToContactAccountant:    raw.okToContactAccountant,
  })

  // Required field validation
  if (typeof raw.name !== 'string' || !raw.name.trim())
    return NextResponse.json({ error: 'Missing required field: Client Name' }, { status: 422 })
  if (typeof raw.harvestProjectCode !== 'string' || !raw.harvestProjectCode.trim())
    return NextResponse.json({ error: 'Missing required field: Project Code' }, { status: 422 })
  if (typeof raw.processingCadence !== 'string' || !raw.processingCadence.trim())
    return NextResponse.json({ error: 'Missing required field: Processing Cadence' }, { status: 422 })

  // Coercion helpers — each returns a safe value or null/default
  const toStr   = (v: unknown) => typeof v === 'string' ? v.trim() || null : null
  const toBool  = (v: unknown, def = false) => typeof v === 'boolean' ? v : def
  const toDate  = (v: unknown) => typeof v === 'string' && v.trim() ? new Date(v) : null
  const toInt   = (v: unknown) => { const n = parseInt(String(v), 10); return isNaN(n) ? null : n }
  const toFloat = (v: unknown) => { const n = parseFloat(String(v)); return isNaN(n) ? null : n }

  try {
    const client = await prisma.client.create({
      data: {
        name:                     raw.name.trim(),
        harvestProjectCode:       (raw.harvestProjectCode as string).trim().toUpperCase(),
        processingCadence:        raw.processingCadence as never,
        accountantName:           toStr(raw.accountantName),
        entityType:               typeof raw.entityType === 'string' ? raw.entityType as never : undefined,
        einNumber:                toStr(raw.einNumber),
        contractStartDate:        toDate(raw.contractStartDate),
        officeType:               typeof raw.officeType === 'string' ? raw.officeType as never : undefined,
        hasPayroll:               toBool(raw.hasPayroll),
        payrollProvider:          toStr(raw.payrollProvider),
        referredBy:               toStr(raw.referredBy),
        projectType:              typeof raw.projectType === 'string' ? raw.projectType as never : undefined,
        revenueType:              typeof raw.revenueType === 'string' ? raw.revenueType as never : undefined,
        guaranteedDeadlineDay:    toInt(raw.guaranteedDeadlineDay),
        autoPriceIncreasePercent: toFloat(raw.autoPriceIncreasePercent),
        priceAdjustmentDate:      toDate(raw.priceAdjustmentDate),
        okToContactAccountant:    toBool(raw.okToContactAccountant),
        primaryContact:           toStr(raw.primaryContact),
        phone:                    toStr(raw.phone),
        email:                    toStr(raw.email),
        address:                  toStr(raw.address),
      },
    })

    console.log('[POST /api/clients] created:', client.id, client.harvestProjectCode)

    revalidatePath('/')
    revalidatePath('/clients')

    return NextResponse.json({ client }, {
      status: 201,
      headers: { 'Cache-Control': 'no-store, max-age=0, must-revalidate' },
    })
  } catch (err) {
    console.error('[POST /api/clients] database error:', err)
    const msg = err instanceof Error ? err.message : String(err)
    if (msg.includes('Unique constraint') || msg.includes('unique')) {
      return NextResponse.json(
        { error: `Project code "${(raw.harvestProjectCode as string).trim().toUpperCase()}" already exists` },
        { status: 409 }
      )
    }
    return NextResponse.json({ error: msg }, { status: 500 })
  }
}
